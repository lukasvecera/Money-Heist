  m_Script: {fileID: 11500000, guid: 885bba7728ad07549a93f95d5f844caf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 1043224118}
  NPCName: {fileID: 524486407}
  playerInteractionPanel: {fileID: 293465029}
  dialogueText: {fileID: 15408440}
  defaultDialogue:
  - Moscow told you how it began.
  - Now let me tell you what it cost.
  - We thought we were in control... but the chaos grew day by day.
  - Hostages tried to rebel.
  - Cops tried to trick us.
  - "Some of us made mistakes \u2014 dangerous ones."
  - And even among us, the team, trust started to crack.
  - There were betrayals, heartbreaks... and blood.
  - We lost people. Good people.
  - But even in all that madness, the Professor never gave up.
  - And neither did we.
  - "Because in the end \u2014 it wasn't just about the money."
  - It was about freedom. About proving we could beat the system.
  - "And somehow\u2026 we did."
  inactiveDialogue:
  - Come again later...
  relatedQuestName: Escape from the bank
  allowedQuestName: Escape from the bank
  contButton: {fileID: 26907104}
  wordSpeed: 0.03

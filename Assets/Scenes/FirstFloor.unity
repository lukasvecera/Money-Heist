  m_Script: {fileID: 11500000, guid: 885bba7728ad07549a93f95d5f844caf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 1469812208}
  NPCName: {fileID: 382293982}
  playerInteractionPanel: {fileID: 2092212084}
  dialogueText: {fileID: 1902349522}
  defaultDialogue:
  - "Hey, I see you have some free time right now, don\u2019t you?"
  - "Listen, I\u2019m starting to feel really bored, and I\u2019d like to read a
    book from the office."
  - "It should be the office on the left \u2014 the one Nairobi always goes to."
  - "Could you please find that book? I\u2019ll go and take her there later."
  - The book should be on the first shelf of the bookshelf.
  - "Also, it\u2019s black and should be called \u201CFrench Kiss.\u201D"
  - "Don\u2019t ask me why I want to read it \u2014 just don\u2019t..."
  inactiveDialogue:
  - There's nothing I can say right now...
  relatedQuestName: Find Helsinki's book
  allowedQuestName: Talk to Helsinki
  contButton: {fileID: 770459965}
  wordSpeed: 0.03
  playerIsClose: 0

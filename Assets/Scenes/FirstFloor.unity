  NPCName: {fileID: 63293347}
  playerInteractionPanel: {fileID: 2092212084}
  dialogueText: {fileID: 2032099366}
  defaultDialogue:
  - Hey there! I hope you're doing well!
  - Are you ready to escape and become a millionaire?
  - I just can't wait!
  - Anyway, we still have some tasks to do and I need your help...
  - Could you please find the access data on the laptop on the second floor?
  - I'm pretty sure I left it on one of the four tables in front of me.
  - After you find it, could you please hack the cameras using the laptop?
  - I know, I know, usually it's my job, but i don't have enough time right now...
  - Thank you! I always knew I could rely on you!
  inactiveDialogue:
  - I have nothing to offer or tell you, sorry...
  relatedQuestName: Find access data
  allowedQuestName: Talk to Rio
  contButton: {fileID: 1068734945}
  wordSpeed: 0.03
  playerIsClose: 0

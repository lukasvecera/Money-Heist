MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 358543010}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 885bba7728ad07549a93f95d5f844caf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 948877941}
  NPCName: {fileID: 1013224872}
  playerInteractionPanel: {fileID: 731005218}
  dialogueText: {fileID: 1153755058}
  defaultDialogue:
  - Finally, you're here. I've been waiting for you for so long...
  - Look, I need you to do something for me.
  - "There\u2019s a very important item in one of the wooden chests in the underground."
  - "I don\u2019t have time to go pick it up \u2014 would you mind doing it for me?"
  - The chest needs a 4-digit code. Luckily, I remember it.
  - 'The code is: 4921.'
  - But only one chest can be unlocked, so I left a map on the first floor.
  - The map is in the office.
  - The office is located to the left of the toilets.
  - Now go and complete this task!
  inactiveDialogue:
  - Sorry, don't have time for you...
  relatedQuestName: Open the chest
  allowedQuestName: Talk to Berlin
  contButton: {fileID: 1195270189}
  wordSpeed: 0.03
  playerIsClose: 0
